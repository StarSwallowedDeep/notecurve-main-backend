package com.notecurve.kafka.consumer;

import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Component;

import com.notecurve.kafka.event.AdminEvent;
import com.notecurve.post.service.PostService;
import com.notecurve.user.service.UserService;
import com.notecurve.user.domain.User;
import com.notecurve.messageboard.service.CommentService;
import com.notecurve.messageboard.service.MessageBoardService;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

@Slf4j
@Component
@RequiredArgsConstructor
public class AdminEventConsumer {

    private final PostService postService;
    private final UserService userService;
    private final CommentService commentService;
    private final MessageBoardService messageBoardService;

    @KafkaListener(topics = "admin-events", groupId = "main-service")
    public void consumeAdminEvent(AdminEvent event) {
        log.info(">>>> [메인] 어드민 이벤트 도착: {}", event);

        if ("DELETED".equals(event.getType())) {
            switch (event.getTarget()) {
                case "USER"          -> userService.adminDeleteUser(event.getTargetId());
                case "POST"          -> postService.adminDeletePost(event.getTargetId());
                case "COMMENT"       -> commentService.adminDeleteComment(event.getTargetId());
                case "MESSAGE_BOARD" -> messageBoardService.adminDeleteMessageBoard(event.getTargetId());
                default -> log.warn(">>>> [메인] 알 수 없는 target: {}", event.getTarget());
            }
        } else if ("ROLE_UPDATED".equals(event.getType())) {
            userService.updateUserRole(event.getTargetId(), User.Role.valueOf(event.getRole()));
        }
    }
}
